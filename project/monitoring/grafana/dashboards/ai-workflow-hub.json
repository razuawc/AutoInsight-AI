{
  "title": "AI Workflow Hub - Overview",
  "uid": "ai-workflow-hub",
  "version": 1,
  "timezone": "browser",
  "schemaVersion": 38,
  "tags": ["ai", "workflow", "automation"],
  "panels": [
    {
      "title": "Workflow Execution Status",
      "type": "stat",
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 80}
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "rate(http_requests_total{status=~\"2..\"}[5m])",
          "legendFormat": "Success Rate"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 8, "h": 8}
    },
    {
      "title": "API Response Times (95th Percentile)",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency"
        }
      ],
      "gridPos": {"x": 8, "y": 0, "w": 8, "h": 8}
    },
    {
      "title": "HTTP Request Rate",
      "type": "graph",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(http_requests_total[5m])",
          "legendFormat": "{{status}}"
        }
      ],
      "gridPos": {"x": 16, "y": 0, "w": 8, "h": 8}
    },
    {
      "title": "Workflow Executions",
      "type": "table",
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT workflow_name, status, COUNT(*) as count, AVG(duration_ms) as avg_duration FROM workflow_executions GROUP BY workflow_name, status ORDER BY count DESC",
          "format": "table"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 12, "h": 8}
    },
    {
      "title": "Recent AI Outputs",
      "type": "table",
      "datasource": "PostgreSQL",
      "targets": [
        {
          "rawSql": "SELECT prompt_type, model, input_tokens, output_tokens, generated_at FROM ai_outputs ORDER BY generated_at DESC LIMIT 20",
          "format": "table"
        }
      ],
      "gridPos": {"x": 12, "y": 8, "w": 12, "h": 8}
    }
  ]
}
